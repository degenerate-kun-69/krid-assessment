# ──────────────────────────────────────────────────────────────
# MongoDB Atlas
# ──────────────────────────────────────────────────────────────
# Get this from: Atlas → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=krid_whatsapp

# ──────────────────────────────────────────────────────────────
# Twilio WhatsApp API  (see TWILIO_SETUP.md for how to get these)
# ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=<your_twilio_account_sid>
TWILIO_AUTH_TOKEN=<your_twilio_auth_token>
# Twilio Sandbox number (default) or your approved WhatsApp sender
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Gemini API (Cloud LLM) ─────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# ──────────────────────────────────────────────────────────────
# Public Base URL  (used to build media asset URLs for Twilio)
# ──────────────────────────────────────────────────────────────
# For local dev: http://localhost:8080
# For production: https://<your-app>.onrender.com
BASE_URL=http://localhost:8080
