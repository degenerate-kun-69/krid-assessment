# ──────────────────────────────────────────────────────────────
# MongoDB Atlas
# ──────────────────────────────────────────────────────────────
# Get this from: Atlas → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=krid_whatsapp

# ──────────────────────────────────────────────────────────────
# Twilio WhatsApp API  (see TWILIO_SETUP.md for how to get these)
# ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=<your_twilio_account_sid>
TWILIO_AUTH_TOKEN=<your_twilio_auth_token>
# Twilio Sandbox number (default) or your approved WhatsApp sender
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ──────────────────────────────────────────────────────────────
# Ollama  (local model server)
# ──────────────────────────────────────────────────────────────
# When running locally: http://localhost:11434
# When running inside Docker: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
